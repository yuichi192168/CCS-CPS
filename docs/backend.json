
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "System user account with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "faculty", "student"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student academic profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "course": { "type": "string" },
        "year": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Graduated", "On Leave"] },
        "email": { "type": "string", "format": "email" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "course", "year", "status", "email"]
    },
    "Faculty": {
      "title": "Faculty",
      "description": "Faculty member profile and specialization details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "specialization": { "type": "string" },
        "publications": { "type": "number" },
        "email": { "type": "string", "format": "email" },
        "image": { "type": "string" }
      },
      "required": ["name", "role", "specialization", "email"]
    },
    "ResearchPaper": {
      "title": "Research Paper",
      "description": "Metadata for a research publication.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "authors": { "type": "string" },
        "year": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "citation": { "type": "number" },
        "abstract": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the faculty who uploaded it." }
      },
      "required": ["title", "authors", "year"]
    },
    "Event": {
      "title": "Event",
      "description": "Academic or extra-curricular event details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["Competition", "Academic", "Administrative", "Workshop"] }
      },
      "required": ["title", "date", "time", "location", "type"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "System users and their roles."
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/backend/entities/Student" },
      "description": "Collection of student profiles."
    },
    "/faculty/{facultyId}": {
      "schema": { "$ref": "#/backend/entities/Faculty" },
      "description": "Collection of faculty profiles."
    },
    "/research/{paperId}": {
      "schema": { "$ref": "#/backend/entities/ResearchPaper" },
      "description": "Repository of research papers."
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/backend/entities/Event" },
      "description": "Academic calendar events."
    }
  }
}

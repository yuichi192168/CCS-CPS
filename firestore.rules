
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Students collection: Public read, Authenticated write
    match /students/{studentId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Faculty collection: Public read, Authenticated write
    match /faculty/{facultyId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Research collection: Public read, Authenticated write
    match /research/{paperId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Events collection: Public read, Authenticated write
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
